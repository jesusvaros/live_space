{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "rootDir": "src",
    "outDir": "dist-scraper",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "isolatedModules": false,
    "verbatimModuleSyntax": false
  },
  "include": [
    "src/config/**/*.ts",
    "src/db/**/*.ts",
    "src/dedupe/**/*.ts",
    "src/normalize/**/*.ts",
    "src/pipeline/**/*.ts",
    "src/scraping/**/*.ts",
    "src/scripts/**/*.ts",
    "src/types/**/*.ts",
    "src/utils/**/*.ts"
  ],
  "exclude": ["src/**/*.tsx", "src/**/*.test.ts", "src/**/*.test.tsx"]
}
