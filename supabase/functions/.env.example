# Copy to supabase/functions/.env.local and keep the real file out of Git.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-with-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key
CLOUDINARY_CLOUD_NAME=replace-with-cloud-name
CLOUDINARY_API_KEY=replace-with-restricted-api-key
CLOUDINARY_API_SECRET=replace-with-api-secret
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,capacitor://localhost
