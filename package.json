{
  "name": "live_space",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.scraper.json",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "db:start": "supabase start",
    "db:reset": "supabase db reset",
    "db:lint": "supabase db lint --local --fail-on error",
    "db:typegen": "supabase gen types typescript --local > src/lib/database.types.ts",
    "functions:serve": "supabase functions serve --env-file supabase/functions/.env.local",
    "recovery:inventory": "python3 tools/recovery/inventory.py",
    "scrape:build": "tsc -p tsconfig.scraper.json",
    "scrape:weekly": "npm run scrape:build && node dist-scraper/scripts/runWeeklyScrape.js",
    "scrape:process": "npm run scrape:build && node dist-scraper/scripts/processPendingStaging.js",
    "scrape:seed": "npm run scrape:build && node dist-scraper/scripts/seedSources.js",
    "scrape:probe": "npm run scrape:build && node dist-scraper/scripts/probeSources.js",
    "scrape:auto-probe": "npm run scrape:build && node dist-scraper/scripts/autoProbeDiscoveredSources.js",
    "scrape:approve-probed": "npm run scrape:build && node dist-scraper/scripts/approveAutoProbedSources.js",
    "venues:discover": "npm run scrape:build && node dist-scraper/scripts/discoverVenues.js"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.1",
    "@capacitor/app": "^8.1.1",
    "@capacitor/camera": "^8.0.0",
    "@capacitor/cli": "^8.0.1",
    "@capacitor/core": "^8.0.1",
    "@capacitor/filesystem": "^8.0.0",
    "@capacitor/ios": "^8.0.1",
    "@maplibre/maplibre-gl-leaflet": "0.1.3",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.90.1",
    "@types/leaflet": "^1.9.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exifr": "^7.1.3",
    "ionicons": "^8.0.13",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.555.0",
    "maplibre-gl": "^4.0.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.18.1",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.2",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "playwright": "^1.61.1",
    "supabase": "^2.109.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.3.1",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.7"
  }
}
